The tldraw watermark is part of tldraw's license. It is shown for unlicensed
or "licensed-with-watermark" users. By using this library, you agree to
preserve the watermark's behavior, keeping it visible, unobscured, and
available to user-interaction.

To remove the watermark, please purchase a license at tldraw.dev.
*/

	.${t} {
		position: absolute;
		bottom: var(--space-2);
		right: var(--space-2);
		width: 96px;
		height: 32px;
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: var(--layer-watermark) !important;
		background-color: color-mix(in srgb, var(--color-background) 62%, transparent);
		opacity: 1;
		border-radius: 5px;
		pointer-events: all;
		padding: 2px;
		box-sizing: content-box;
	}

	.${t} > button {
		position: absolute;
		width: 96px;
		height: 32px;
		pointer-events: all;
		cursor: inherit;
		color: var(--color-text);
		opacity: .38;
		border: 0;
		padding: 0;
		background-color: currentColor;
	}

	.${t}[data-debug='true'] {
		bottom: 46px;
	}

	.${t}[data-mobile='true'] {
		border-radius: 4px 0px 0px 4px;
		right: -2px;
		width: 8px;
		height: 48px;
	}

	.${t}[data-mobile='true'] > button {
		width: 8px;
		height: 32px;
	}

	@media (hover: hover) {
		.${t} > button {
			pointer-events: none;
		}

		.${t}:hover {
			background-color: var(--color-background);
			transition: background-color 0.2s ease-in-out;
			transition-delay: 0.32s;
		}

		.${t}:hover > button {
			animation: ${t}_delayed_link 0.2s forwards ease-in-out;
			animation-delay: 0.32s;
		}

		.${t} > button:focus-visible {
			opacity: 1;
		}
	}


	@keyframes ${t}_delayed_link {
		0% {
			cursor: inherit;
			opacity: .38;
			pointer-events: none;
		}
		100% {
			cursor: pointer;
			opacity: 1;
			pointer-events: all;
		}
	}`;return(0,y.jsx)("style",{nonce:e.options.nonce,children:m})}),ex=[],ew=[],ev=[],eS=(0,k.memo)(function({store:e,components:t,className:m,user:z,options:q,...Q}){let[ee,et]=(0,k.useState)(null),en=(0,k.useMemo)(()=>z??(0,B.L)(),[z]),ei=t?.ErrorFallback===void 0?O.d:t?.ErrorFallback,es={...Q,shapeUtils:Q.shapeUtils??ex,bindingUtils:Q.bindingUtils??ew,tools:Q.tools??ev,components:t,options:(0,eo.S)(q)};return(0,y.jsx)("div",{ref:et,"data-tldraw":C.i,draggable:!1,className:E("tl-container tl-theme__light",m),onPointerDown:ep.be,tabIndex:-1,role:"application","aria-label":q?.branding??"tldraw",children:(0,y.jsx)(I.e,{fallback:ei,onError:e=>(0,S.lw)(e,{tags:{origin:"react.tldraw-before-app"}}),children:ee&&(0,y.jsx)(LicenseProvider,{licenseKey:Q.licenseKey,children:(0,y.jsx)($.jm,{container:ee,children:(0,y.jsx)(er.I,{overrides:t,children:e?e instanceof v.yh?(0,y.jsx)(TldrawEditorWithReadyStore,{...es,store:e,user:en}):(0,y.jsx)(ek,{...es,store:e,user:en}):(0,y.jsx)(TldrawEditorWithOwnStore,{...es,store:e,user:en})})})})})})});function TldrawEditorWithOwnStore(e){let{defaultName:t,snapshot:m,initialData:v,shapeUtils:S,bindingUtils:k,persistenceKey:E,sessionId:C,user:I,assets:O,migrations:B}=e,z=(0,es.h)({shapeUtils:S,bindingUtils:k,initialData:v,persistenceKey:E,sessionId:C,defaultName:t,snapshot:m,assets:O,migrations:B});return(0,y.jsx)(ek,{...e,store:z,user:I})}let ek=(0,k.memo)(function({store:e,user:t,...m}){let v=(0,$.uK)();(0,k.useLayoutEffect)(()=>{"dark"===t.userPreferences.get().colorScheme&&(v.classList.remove("tl-theme__light"),v.classList.add("tl-theme__dark"))},[v,t]);let{LoadingScreen:S}=(0,er.o)();switch(e.status){case"error":throw e.error;case"loading":return S?(0,y.jsx)(S,{}):null}return(0,y.jsx)(TldrawEditorWithReadyStore,{...m,store:e.store,user:t})}),noAutoFocus=()=>document.location.search.includes("tldraw_preserve_focus");function TldrawEditorWithReadyStore({onMount:e,children:t,store:m,tools:v,shapeUtils:S,bindingUtils:E,user:C,initialState:O,au